NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000
DATABASE_URL=mysql://root:@localhost:3306/erp
# Cart works without Redis (in-memory). Set false to skip Redis entirely on the API.
REDIS_ENABLED=true
# Required when REDIS_ENABLED=true (email/commission workers). Start: docker compose up -d redis
REDIS_URL=redis://127.0.0.1:6379
# Min 32 characters (generate a random string for production)
JWT_SECRET=replace_with_at_least_32_character_secret_string
# Access token TTL (examples: 15m, 1h, 24h, 7d)
JWT_EXPIRES_IN=24h

# Public URL of this API (used in uploaded image URLs). Required in production.
# API_PUBLIC_URL=https://qeema-vendor.nodeteam.site
# Or alias: ERP_API_URL=https://qeema-vendor.nodeteam.site

# Optional: Esyasatgo public API base for admin catalog import (default https://api.esyasatgo.com/api)
# ESYASATGO_API_BASE=https://api.esyasatgo.com/api

# SMTP — all emails sent via Nodemailer (Gmail: use App Password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="Esyasatgo <your@gmail.com>"

# Social login (optional — hide buttons when unset)
# GOOGLE_CLIENT_ID=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# APPLE_CLIENT_ID=

# Commission clearing delay after delivery (default 3 days; use 60000 for dev)
# COMMISSION_CLEAR_DELAY_MS=259200000
