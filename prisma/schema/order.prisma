model Order {
  id                Int           @id @default(autoincrement())
  order_number      String        @unique
  customer_id       Int
  status            OrderStatus   @default(pending)
  payment_status    PaymentStatus @default(unpaid)
  payment_method    PaymentMethod
  payment_reference String?
  subtotal          Decimal       @db.Decimal(12, 2)
  shipping_amount   Decimal       @db.Decimal(12, 2) @default(0)
  discount_amount   Decimal       @db.Decimal(12, 2) @default(0)
  coupon_code       String?
  tax_amount        Decimal       @db.Decimal(12, 2) @default(0)
  total_amount      Decimal       @db.Decimal(12, 2)
  currency          String        @default("EGP") @db.VarChar(3)
  shipping_address_id Int
  billing_address_id  Int?
  notes             String?       @db.Text
  ip_address        String?
  deleted_at        DateTime?
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt
  customer          User          @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  shipping_address  Address       @relation("OrderShippingAddress", fields: [shipping_address_id], references: [id], onDelete: Restrict)
  billing_address   Address?      @relation("OrderBillingAddress", fields: [billing_address_id], references: [id], onDelete: SetNull)
  sub_orders        SubOrder[]
  payment_logs      PaymentLog[]
  tracking          OrderTracking[]
  coupon_usages     CouponUsage[]
  installments      InstallmentPlan[]
  invoices          Invoice[]
  tracking_events   OrderTrackingEvent[]

  @@index([customer_id, created_at])
  @@index([status, created_at])
  @@index([created_at])
  @@index([deleted_at])
}

model SubOrder {
  id               Int         @id @default(autoincrement())
  order_id         Int
  merchant_id      Int
  status           SubOrderStatus @default(pending)
  subtotal         Decimal     @db.Decimal(12, 2)
  shipping_amount  Decimal     @db.Decimal(12, 2) @default(0)
  discount_amount  Decimal     @db.Decimal(12, 2) @default(0)
  tax_amount       Decimal     @db.Decimal(12, 2) @default(0)
  total_amount     Decimal     @db.Decimal(12, 2)
  commission_rate  Decimal     @db.Decimal(5,2) @default(0)
  commission_amount Decimal    @db.Decimal(12,2) @default(0)
  deleted_at       DateTime?
  created_at       DateTime    @default(now())
  updated_at       DateTime    @updatedAt
  order            Order       @relation(fields: [order_id], references: [id], onDelete: Cascade)
  merchant         Merchant    @relation(fields: [merchant_id], references: [id], onDelete: Cascade)
  items            OrderItem[]
  commissions      Commission[]
  tracking         OrderTracking[]
  tracking_events  OrderTrackingEvent[]

  @@index([order_id])
  @@index([merchant_id])
  @@index([created_at])
  @@index([deleted_at])
}

model OrderItem {
  id              Int      @id @default(autoincrement())
  sub_order_id    Int
  product_id      Int
  variant_id      Int
  name_ar         String
  name_en         String
  sku             String
  quantity        Int
  unit_price      Decimal  @db.Decimal(12, 2)
  total_price     Decimal  @db.Decimal(12, 2)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  sub_order       SubOrder @relation(fields: [sub_order_id], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [product_id], references: [id], onDelete: Restrict)
  variant         ProductVariant @relation(fields: [variant_id], references: [id], onDelete: Restrict)
  returns         Return[]
  reviews         ProductReview[]

  @@index([sub_order_id])
  @@index([product_id])
  @@index([variant_id])
  @@index([created_at])
}

model OrderTracking {
  id          Int      @id @default(autoincrement())
  order_id    Int
  sub_order_id Int?
  status      String
  note        String?
  location    String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  order       Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)
  sub_order   SubOrder? @relation(fields: [sub_order_id], references: [id], onDelete: SetNull)

  @@index([order_id])
  @@index([sub_order_id])
}

model OrderTrackingEvent {
  id                      Int                     @id @default(autoincrement())
  order_id                Int
  sub_order_id            Int?
  actor_type              OrderTrackingActorType
  actor_user_id           Int?
  event_code              String                  @db.VarChar(64)
  title                   String                  @db.VarChar(255)
  description             String?                 @db.Text
  location                String?                 @db.VarChar(255)
  carrier_code            String?                 @db.VarChar(64)
  external_tracking_id    String?                 @db.VarChar(128)
  external_tracking_url   String?                 @db.VarChar(1024)
  metadata                Json?
  visible_to_customer     Boolean                 @default(true)
  occurred_at             DateTime                @default(now())
  order                   Order                   @relation(fields: [order_id], references: [id], onDelete: Cascade)
  sub_order               SubOrder?               @relation(fields: [sub_order_id], references: [id], onDelete: SetNull)
  actor_user              User?                   @relation("OrderTrackingEventActor", fields: [actor_user_id], references: [id], onDelete: SetNull)

  @@index([order_id, occurred_at])
  @@index([sub_order_id, occurred_at])
  @@index([actor_type, occurred_at])
}

model Return {
  id               Int          @id @default(autoincrement())
  order_item_id    Int
  customer_id      Int
  reason           ReturnReason
  status           ReturnStatus @default(pending)
  refund_method    RefundMethod
  requested_amount Decimal      @db.Decimal(12,2)
  approved_amount  Decimal?     @db.Decimal(12,2)
  rejection_reason String?
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt
  order_item       OrderItem    @relation(fields: [order_item_id], references: [id], onDelete: Restrict)
  customer         User         @relation("ReturnCustomer", fields: [customer_id], references: [id], onDelete: Cascade)

  @@index([order_item_id])
  @@index([customer_id])
  @@index([status])
}

model InstallmentPlan {
  id             Int                 @id @default(autoincrement())
  order_id        Int
  provider        InstallmentProvider
  status          InstallmentStatus  @default(pending)
  tenure_months   Int
  interest_rate   Decimal            @db.Decimal(5,2) @default(0)
  total_amount    Decimal            @db.Decimal(12,2)
  monthly_amount  Decimal            @db.Decimal(12,2)
  created_at      DateTime           @default(now())
  updated_at      DateTime           @updatedAt
  order           Order              @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([order_id])
  @@index([status])
}

model Coupon {
  id                   Int          @id @default(autoincrement())
  code                 String       @unique
  type                 CouponType
  value                Decimal      @db.Decimal(12,2)
  max_discount_amount  Decimal?     @db.Decimal(12,2)
  min_order_amount     Decimal?     @db.Decimal(12,2)
  applicable_to        ApplicableTo
  usage_limit          Int?
  usage_limit_per_user Int?
  used_count           Int          @default(0)
  starts_at            DateTime
  ends_at              DateTime
  is_active            Boolean      @default(true)
  deleted_at           DateTime?
  created_at           DateTime     @default(now())
  updated_at           DateTime     @updatedAt
  usages               CouponUsage[]

  @@index([deleted_at])
}

model CouponUsage {
  id          Int      @id @default(autoincrement())
  coupon_id   Int
  customer_id Int
  order_id    Int
  used_at     DateTime @default(now())
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  coupon      Coupon   @relation(fields: [coupon_id], references: [id], onDelete: Cascade)
  customer    User     @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  order       Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([coupon_id])
  @@index([customer_id])
  @@index([order_id])
}

model Invoice {
  id             Int           @id @default(autoincrement())
  order_id        Int
  invoice_number  String       @unique
  status          InvoiceStatus @default(pending)
  issue_date      DateTime?
  due_date        DateTime?
  subtotal        Decimal      @db.Decimal(12,2)
  tax_amount      Decimal      @db.Decimal(12,2) @default(0)
  total_amount    Decimal      @db.Decimal(12,2)
  pdf_url         String?
  archived_at     DateTime?
  archived_by_user_id Int?
  archive_uri     String?       @db.Text
  archive_fingerprint String?   @db.VarChar(128)
  archive_tier    InvoiceArchiveTier?
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  order           Order        @relation(fields: [order_id], references: [id], onDelete: Cascade)
  archived_by     User?        @relation("InvoiceArchivedBy", fields: [archived_by_user_id], references: [id], onDelete: SetNull)

  @@index([order_id])
  @@index([status])
  @@index([archived_at])
}
