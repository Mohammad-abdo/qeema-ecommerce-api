model StorefrontStory {
  id              Int                   @id @default(autoincrement())
  vendor_name     String
  vendor_name_tr  String?
  vendor_name_ar  String?
  merchant_id     Int?
  is_active       Boolean               @default(true)
  is_admin        Boolean               @default(false)
  link_type       String                @default("product")
  sort_order      Int                   @default(0)
  created_at      DateTime              @default(now())
  updated_at      DateTime              @updatedAt
  items           StorefrontStoryItem[]

  @@index([is_active, sort_order])
}

model StorefrontStoryItem {
  id          Int             @id @default(autoincrement())
  story_id    Int
  thumbnail   String?
  media_url   String
  media_type  String          @default("image")
  duration    Int             @default(5)
  link_type   String          @default("product")
  link_id     String?
  sort_order  Int             @default(0)
  is_active   Boolean         @default(true)
  created_at  DateTime        @default(now())
  updated_at  DateTime        @updatedAt
  story       StorefrontStory @relation(fields: [story_id], references: [id], onDelete: Cascade)

  @@index([story_id, sort_order])
}
