// Classified-style site listings: admin or merchant submits; admin reviews before publish.

model SiteListingCategory {
  id         Int                   @id @default(autoincrement())
  parent_id  Int?
  slug       String                @unique @db.VarChar(128)
  name_ar    String                @db.VarChar(255)
  name_en    String                @db.VarChar(255)
  sort_order Int                   @default(0)
  is_active  Boolean               @default(true)
  deleted_at DateTime?
  created_at DateTime              @default(now())
  updated_at DateTime              @updatedAt
  parent     SiteListingCategory?  @relation("SiteListingCategoryTree", fields: [parent_id], references: [id], onDelete: SetNull)
  children   SiteListingCategory[] @relation("SiteListingCategoryTree")
  listings   SiteListing[]

  @@index([parent_id])
  @@index([deleted_at])
}

model SiteListing {
  id                   Int                      @id @default(autoincrement())
  category_id          Int
  merchant_id          Int?
  created_by_user_id   Int
  publisher_type       SiteListingPublisherType
  title                String                   @db.VarChar(255)
  body                 String                   @db.LongText
  images               Json?
  price                Decimal?                 @db.Decimal(12, 2)
  currency             String?                  @db.VarChar(3)
  location_label       String?                  @db.VarChar(255)
  contact_phone        String?                  @db.VarChar(32)
  contact_email        String?                  @db.VarChar(255)
  status               SiteListingStatus        @default(pending_review)
  reviewed_by_user_id  Int?
  reviewed_at          DateTime?
  rejection_reason     String?                  @db.Text
  published_at         DateTime?
  expires_at           DateTime?
  view_count           Int                      @default(0)
  featured             Boolean                  @default(false)
  deleted_at           DateTime?
  created_at           DateTime                 @default(now())
  updated_at           DateTime                 @updatedAt
  category             SiteListingCategory      @relation(fields: [category_id], references: [id], onDelete: Restrict)
  merchant             Merchant?                @relation(fields: [merchant_id], references: [id], onDelete: SetNull)
  author               User                     @relation("SiteListingAuthor", fields: [created_by_user_id], references: [id], onDelete: Restrict)
  reviewer             User?                    @relation("SiteListingReviewer", fields: [reviewed_by_user_id], references: [id], onDelete: SetNull)

  @@index([category_id, status])
  @@index([merchant_id, status])
  @@index([status, published_at])
  @@index([created_by_user_id])
  @@index([deleted_at])
}
