model PaymentLog {
  id                Int      @id @default(autoincrement())
  order_id          Int?
  gateway           String
  event_type        String
  transaction_id    String?
  amount            Decimal? @db.Decimal(12, 2)
  currency          String?  @db.VarChar(3)
  payload           Json
  provider_response Json?
  failure_reason    String?
  signature         String?
  status            TxStatus?
  idempotency_key   String   @unique
  processed_at      DateTime?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  order             Order?   @relation(fields: [order_id], references: [id], onDelete: SetNull)

  @@index([order_id])
  @@index([gateway])
  @@index([event_type])
  @@index([created_at])
}

model Wallet {
  id         Int         @id @default(autoincrement())
  owner_type WalletOwner
  owner_id   Int
  balance    Decimal     @db.Decimal(12,2) @default(0)
  is_active  Boolean     @default(true)
  created_at DateTime    @default(now())
  updated_at DateTime    @updatedAt
  transactions WalletTransaction[]

  @@unique([owner_type, owner_id])
}

model WalletTransaction {
  id             Int        @id @default(autoincrement())
  wallet_id      Int
  type           TxType
  category       TxCategory
  amount         Decimal    @db.Decimal(12,2)
  balance_before Decimal?   @db.Decimal(12,2)
  balance_after  Decimal?   @db.Decimal(12,2)
  status         TxStatus   @default(pending)
  reference_type String?
  reference_id   String?
  note           String?
  created_by     Int?
  created_at     DateTime   @default(now())
  updated_at     DateTime   @updatedAt
  wallet         Wallet     @relation(fields: [wallet_id], references: [id], onDelete: Cascade)
  creator        User?      @relation("WalletTxCreator", fields: [created_by], references: [id], onDelete: SetNull)

  @@index([wallet_id])
  @@index([category])
}

model Commission {
  id           Int              @id @default(autoincrement())
  sub_order_id Int
  merchant_id  Int
  rate         Decimal          @db.Decimal(5,2)
  gross_amount Decimal          @db.Decimal(12,2)
  amount       Decimal          @db.Decimal(12,2)
  status       CommissionStatus @default(pending)
  cleared_at   DateTime?
  paid_at      DateTime?
  created_at   DateTime         @default(now())
  updated_at   DateTime         @updatedAt
  sub_order    SubOrder         @relation(fields: [sub_order_id], references: [id], onDelete: Cascade)
  merchant     Merchant         @relation(fields: [merchant_id], references: [id], onDelete: Cascade)

  @@index([sub_order_id])
  @@index([merchant_id])
  @@index([status])
}

model Payout {
  id           Int          @id @default(autoincrement())
  merchant_id  Int
  amount       Decimal      @db.Decimal(12,2)
  method       PayoutMethod
  status       PayoutStatus @default(pending)
  reference    String?
  note         String?
  processed_at DateTime?
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt
  merchant     Merchant     @relation(fields: [merchant_id], references: [id], onDelete: Cascade)

  @@index([merchant_id])
  @@index([status])
}
