model User {
  id                 Int       @id @default(autoincrement())
  email              String    @unique
  phone              String?   @unique
  name               String
  avatar             String?
  password_hash      String?
  role               UserRole
  oauth_accounts     UserOAuthAccount[]
  is_active          Boolean   @default(true)
  email_verified_at  DateTime?
  phone_verified_at  DateTime?
  last_login_at      DateTime?
  last_login_ip      String?
  deleted_at         DateTime?
  suspended_at       DateTime?
  suspension_reason  String?   @db.Text
  banned_at          DateTime?
  ban_reason         String?   @db.Text
  last_moderated_at  DateTime?
  last_moderated_by  Int?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  account_moderator  User?     @relation("UserAccountModerator", fields: [last_moderated_by], references: [id], onDelete: SetNull)
  moderated_users    User[]    @relation("UserAccountModerator")
  sessions           Session[]
  orders             Order[]
  merchant           Merchant?
  audit_logs         AuditLog[]
  employee           Employee?
  addresses          Address[]
  approved_merchants Merchant[]           @relation("MerchantApprover")
  approved_products  Product[]          @relation("ProductApprover")
  approved_leaves    LeaveRequest[]     @relation("LeaveApprover")
  payrolls_created   Payroll[]          @relation("PayrollCreator")
  inventory_logs     InventoryLog[]     @relation("InventoryLogCreator")
  wallet_tx_created  WalletTransaction[] @relation("WalletTxCreator")
  returns            Return[]           @relation("ReturnCustomer")
  notifications      Notification[]
  notification_pref  NotificationPreference?
  review_helpful     ReviewHelpful[]
  product_reviews    ProductReview[]
  store_reviews      StoreReview[]
  wishlist           Wishlist[]
  recently_viewed    RecentlyViewed[]
  coupon_usages      CouponUsage[]
  loyalty_points     LoyaltyPoint[]
  carts              Cart[]
  support_tickets_customer SupportTicket[] @relation("TicketCustomer")
  support_tickets_assigned SupportTicket[] @relation("TicketAssignee")
  support_messages   SupportMessage[]   @relation("SupportMessageSender")
  reviewed_documents MerchantDocument[] @relation("DocumentReviewer")
  translation_permissions TranslationPermission[]
  translation_jobs          TranslationJob[]          @relation("TranslationJobCreator")
  translation_reviews     TranslationReview[]       @relation("TranslationReviewReviewer")
  translation_drafts        TranslationDraft[]        @relation("TranslationDraftEditor")
  translation_publishes     Translation[]             @relation("TranslationPublisher")
  translation_versions      TranslationVersion[]      @relation("TranslationVersionAuthor")
  translation_audits        TranslationAudit[]        @relation("TranslationAuditActor")
  entity_translations       EntityTranslation[]       @relation("EntityTranslationAuthor")
  report_definitions_owned  ReportDefinition[]        @relation("ReportDefinitionOwner")
  report_runs_requested     ReportRun[]               @relation("ReportRunRequester")
  report_schedules_created  ReportSchedule[]          @relation("ReportScheduleCreator")
  merchants_moderated       Merchant[]                @relation("MerchantModerationActor")
  invoices_archived         Invoice[]                 @relation("InvoiceArchivedBy")
  order_tracking_events_as_actor OrderTrackingEvent[] @relation("OrderTrackingEventActor")
  site_listings_authored    SiteListing[]             @relation("SiteListingAuthor")
  site_listings_reviewed    SiteListing[]             @relation("SiteListingReviewer")
  special_offers_created    SpecialOffer[]            @relation("SpecialOfferCreator")

  @@index([role])
  @@index([created_at])
  @@index([deleted_at])
  @@index([suspended_at])
  @@index([banned_at])
}

model UserOAuthAccount {
  id          Int      @id @default(autoincrement())
  user_id     Int
  provider    String   @db.VarChar(32)
  provider_id String   @db.VarChar(255)
  email       String?  @db.VarChar(255)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([provider, provider_id])
  @@index([user_id])
}

model Address {
  id            Int      @id @default(autoincrement())
  user_id       Int?
  label         String?
  full_name     String
  phone         String?
  country       String
  city          String
  district      String?
  street        String
  building      String?
  floor         String?
  apartment     String?
  postal_code   String?
  latitude      Decimal? @db.Decimal(10, 7)
  longitude     Decimal? @db.Decimal(10, 7)
  is_default    Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  user          User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)
  orders_shipping Order[] @relation("OrderShippingAddress")
  orders_billing  Order[] @relation("OrderBillingAddress")

  @@index([user_id])
  @@index([city, country])
}

model Cart {
  id          String     @id @default(cuid())
  customer_id Int      @unique
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt
  customer    User       @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  items       CartItem[]
  reservations StockReservation[]

  @@index([customer_id])
}

model CartItem {
  id         Int            @id @default(autoincrement())
  cart_id    String
  variant_id Int
  quantity   Int            @default(1)
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt
  cart       Cart           @relation(fields: [cart_id], references: [id], onDelete: Cascade)
  variant    ProductVariant @relation(fields: [variant_id], references: [id], onDelete: Cascade)

  @@unique([cart_id, variant_id])
  @@index([variant_id])
}

model Department {
  id          Int        @id @default(autoincrement())
  name        String
  code        String     @unique
  manager_id  Int?
  description String?
  is_active   Boolean    @default(true)
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt
  manager     Employee?  @relation("DepartmentManager", fields: [manager_id], references: [id], onDelete: SetNull)
  employees   Employee[] @relation("DepartmentEmployees")

  @@unique([manager_id])
  @@index([manager_id])
}

model Employee {
  id                      Int            @id @default(autoincrement())
  user_id                 Int            @unique
  department_id           Int
  employee_code           String         @unique
  position                String
  salary                  Decimal        @db.Decimal(12,2)
  hire_date               DateTime       @db.Date
  national_id             String         @unique
  national_id_scan        String?
  contract_type           ContractType
  contract_file           String?
  emergency_contact_name  String?
  emergency_contact_phone String?
  status                  EmployeeStatus @default(active)
  terminated_at           DateTime?
  termination_reason      String?
  created_at              DateTime       @default(now())
  updated_at              DateTime       @updatedAt
  user                    User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  department              Department     @relation("DepartmentEmployees", fields: [department_id], references: [id])
  managed_department      Department?    @relation("DepartmentManager")
  attendances             Attendance[]
  leave_requests          LeaveRequest[]
  payrolls                Payroll[]
  permissions             EmployeePermission[]

  @@index([user_id])
  @@index([department_id])
  @@index([status])
}

model Attendance {
  id           Int              @id @default(autoincrement())
  employee_id  Int
  date         DateTime         @db.Date
  check_in     DateTime?
  check_out    DateTime?
  status       AttendanceStatus
  late_minutes Int              @default(0)
  notes        String?
  created_at   DateTime         @default(now())
  updated_at   DateTime         @updatedAt
  employee     Employee         @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@unique([employee_id, date])
  @@index([employee_id, date])
}

model LeaveRequest {
  id               Int         @id @default(autoincrement())
  employee_id      Int
  type             LeaveType
  start_date       DateTime    @db.Date
  end_date         DateTime    @db.Date
  total_days       Int
  reason           String
  status           LeaveStatus @default(pending)
  approved_by      Int?
  approved_at      DateTime?
  rejection_reason String?
  created_at       DateTime    @default(now())
  updated_at       DateTime    @updatedAt
  employee         Employee    @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  approver         User?       @relation("LeaveApprover", fields: [approved_by], references: [id], onDelete: SetNull)

  @@index([employee_id, status])
}

model Payroll {
  id           Int           @id @default(autoincrement())
  employee_id  Int
  month        Int
  year         Int
  basic_salary Decimal       @db.Decimal(12,2)
  allowances   Decimal       @db.Decimal(12,2) @default(0)
  deductions   Decimal       @db.Decimal(12,2) @default(0)
  net_salary   Decimal       @db.Decimal(12,2)
  status       PayrollStatus @default(draft)
  paid_at      DateTime?
  payslip_url  String?
  created_by   Int
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt
  employee     Employee      @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  creator        User          @relation("PayrollCreator", fields: [created_by], references: [id], onDelete: Restrict)

  @@unique([employee_id, month, year])
  @@index([employee_id, year])
}

model NotificationTemplate {
  id                   Int            @id @default(autoincrement())
  code                 String         @unique @db.VarChar(64)
  channel_default      NotifChannel?
  title_template       String         @db.VarChar(255)
  message_template     String         @db.Text
  payload_schema       Json?
  is_active            Boolean        @default(true)
  created_at           DateTime       @default(now())
  updated_at           DateTime       @updatedAt
  notifications        Notification[]

  @@index([is_active])
}

model Notification {
  id                        Int                     @id @default(autoincrement())
  user_id                   Int
  channel                   NotifChannel
  title                     String
  message                   String                  @db.Text
  payload                   Json?
  template_id               String?
  notification_template_id  Int?
  is_read                   Boolean                 @default(false)
  read_at                   DateTime?
  sent_at                   DateTime?
  failed_at                 DateTime?
  retry_count               Int                     @default(0)
  created_at                DateTime                @default(now())
  updated_at                DateTime                @updatedAt
  user                      User                    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  notification_template     NotificationTemplate?   @relation(fields: [notification_template_id], references: [id], onDelete: SetNull)

  @@index([user_id, is_read])
  @@index([notification_template_id])
}

model NotificationPreference {
  id            Int      @id @default(autoincrement())
  user_id       Int      @unique
  order_updates Boolean  @default(true)
  promotions    Boolean  @default(true)
  support       Boolean  @default(true)
  email_enabled Boolean  @default(true)
  sms_enabled   Boolean  @default(false)
  push_enabled  Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id            Int            @id @default(autoincrement())
  ticket_number String         @unique
  customer_id   Int?
  merchant_id   Int?
  assigned_to   Int?
  category      TicketCategory
  status        TicketStatus   @default(open)
  priority      TicketPriority @default(medium)
  subject       String
  description   String         @db.Text
  last_reply_at DateTime?
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  customer      User?          @relation("TicketCustomer", fields: [customer_id], references: [id], onDelete: SetNull)
  merchant      Merchant?      @relation(fields: [merchant_id], references: [id], onDelete: SetNull)
  assignee      User?          @relation("TicketAssignee", fields: [assigned_to], references: [id], onDelete: SetNull)
  messages      SupportMessage[]
  inventory_adjustments InventoryLog[]

  @@index([status, priority])
  @@index([customer_id])
  @@index([merchant_id])
}

model SupportMessage {
  id          Int        @id @default(autoincrement())
  ticket_id   Int
  sender_id   Int
  sender_type SenderType
  message     String     @db.Text
  attachments Json?
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt
  ticket      SupportTicket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  sender      User          @relation("SupportMessageSender", fields: [sender_id], references: [id], onDelete: Cascade)

  @@index([ticket_id])
}
